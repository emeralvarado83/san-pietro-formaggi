generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Prodotto {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  categoria      String
  descrizioneBreve String
  descrizione    String?  @db.Text
  disponibilita  String   @default("Disponibile")
  destacado       Boolean  @default(false)
  immagine       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Ricetta {
  id            String   @id @default(cuid())
  titolo        String
  slug          String   @unique
  indicazioni   String?  @db.Text
  ingredienti   String?  @db.Text
  preparazione  String?  @db.Text
  immagine      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
